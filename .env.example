# Copy this file to .env and fill in your values.
# .env is never committed to the repository.

# Tailscale auth key (generate at https://login.tailscale.com/admin/settings/keys)
TAILSCALE_AUTHKEY=tskey-auth-XXXXX

# Samba user passwords — one variable per user defined in config.yaml
# Variable name: SAMBA_PASSWORD_<USERNAME_UPPERCASED>
SAMBA_PASSWORD_ALICE=changeme
SAMBA_PASSWORD_BOB=changeme

# Notification settings (only needed if notifications.method = email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=nas@example.com

# Notification settings (only needed if notifications.method = webhook)
WEBHOOK_URL=https://hooks.example.com/nas-alerts
